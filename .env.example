# =============================================================================
# Campfire — environment variables template
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.
# =============================================================================

# ── Next.js ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_USE_MOCK=false
NEXT_PUBLIC_DEFAULT_RECON_MODE=free
NEXT_PUBLIC_AUTH_DEV_BYPASS=false

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── External AI / Search APIs ─────────────────────────────────────────────────
TAVILY_API_KEY=tvly-...
OPENAI_API_KEY=sk-...
SERPER_API_KEY=...
JINA_API_KEY=jina_...
HUNTER_API_KEY=...           # optional

# ── Stripe (secondary gateway — card payments) ────────────────────────────────
# Sign up at https://stripe.com → Developers → API keys
# Use test keys (sk_test_...) during development; live keys (sk_live_...) in production.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# For local webhook testing: stripe listen --forward-to localhost:8000/api/webhooks/stripe

# ── Xendit (primary gateway — Indonesian payment methods) ─────────────────────
# Sign up at https://dashboard.xendit.co → Settings → API Keys
# Use development keys (xnd_development_...) during testing; production keys in production.
XENDIT_SECRET_KEY=xnd_development_...
XENDIT_WEBHOOK_TOKEN=your-webhook-verification-token
# Set webhook URL in Xendit Dashboard → Settings → Callbacks:
#   https://your-domain.com/api/webhooks/xendit   (QRIS and Virtual Account)

# ── Resend (email dispatch) ───────────────────────────────────────────────────
RESEND_API_KEY=re_...
# Default sender (used when a user has not set up or verified their own domain)
# Format: "Display Name <email@domain.com>"
RESEND_FROM_EMAIL=Campfire <noreply@campfire.web.id>
# Inbound reply tracking domain (optional — requires Resend Inbound feature)
# Format: subdomain only, e.g. "inbound.campfire.web.id"
RESEND_INBOUND_DOMAIN=
# Shared secret for /api/webhooks/inbound — set the same value in Resend
# Inbound Routing → "Add custom header": X-Resend-Inbound-Token: <value>.
# Without this set, the inbound webhook returns 500 (fail-closed).
RESEND_INBOUND_TOKEN=

# ── Early Access (Phase 5) ────────────────────────────────────────────────────
# All five flags use the NEXT_PUBLIC_ prefix because they gate client-rendered
# UI (sidebar, pricing page, banner, onboarding modal). Next.js will not inline
# non-prefixed env vars into the client bundle. None are secrets.
NEXT_PUBLIC_EARLY_ACCESS_MODE=true
NEXT_PUBLIC_BILLING_ACTIVE=false
NEXT_PUBLIC_FREE_CREDITS_ON_SIGNUP=50
NEXT_PUBLIC_INVITE_ONLY=true
NEXT_PUBLIC_FEEDBACK_WIDGET_ENABLED=true

# Admin dashboard access — used by /admin/usage (Step 5).
# ADMIN_EMAILS: comma-separated allowlist checked against the Supabase session.
# ADMIN_SECRET_KEY: server-only fallback for curl-based admin endpoints.
# Leave both blank until Step 5 is implemented.
ADMIN_EMAILS=
ADMIN_SECRET_KEY=
