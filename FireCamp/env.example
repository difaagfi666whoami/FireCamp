# Mode: gunakan "true" untuk mock data, "false" untuk Supabase + external APIs
NEXT_PUBLIC_USE_MOCK=true

# Nama aplikasi
NEXT_PUBLIC_APP_NAME=Campfire

# FastAPI Backend URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# Supabase (dapatkan dari https://supabase.com > Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# External APIs (hanya dipakai saat NEXT_PUBLIC_USE_MOCK=false)
PROXYCURL_API_KEY=your-proxycurl-api-key
FIRECRAWL_API_KEY=your-firecrawl-api-key
TAVILY_API_KEY=your-tavily-api-key
OPENAI_API_KEY=your-openai-api-key
